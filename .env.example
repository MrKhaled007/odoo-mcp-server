# =============================================================================
# odoo-mcp-server configuration
# Copy this file to .env and fill in your values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Odoo connection
# -----------------------------------------------------------------------------

# Base URL of the Odoo instance (no trailing slash)
ODOO_URL=http://localhost:8069

# Database name
ODOO_DB=odoo_demo

# Username of the service account (NOT a real human user)
ODOO_USERNAME=service_account

# Odoo API key (recommended over password — Odoo 14+ supports these)
# Generate in Odoo: Preferences > Account Security > New API Key
ODOO_API_KEY=replace-with-real-api-key

# Fallback: password authentication (only if API key unavailable)
# ODOO_PASSWORD=

# -----------------------------------------------------------------------------
# Security (see README.md "Security Model" for details)
# -----------------------------------------------------------------------------

# Permission mode: 'read' (default) or 'write' (opt-in only)
# Write mode lets tools create/update/unlink records. Disabled in v1.
MCP_PERMISSION_MODE=read

# Hard cap on records returned per tool call (max 500, default 100)
MCP_MAX_RECORDS=100

# Query timeout in seconds (default 10)
MCP_QUERY_TIMEOUT=10

# Rate limit: calls per minute per client (default 60)
MCP_RATE_LIMIT=60

# Audit log path (rotating, append-only)
MCP_AUDIT_PATH=./logs/audit.log

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
